# =====================================================
# Environment Variables Configuration
# Copy this file to .env and fill in your values
# =====================================================

# ===== SERVER =====
SERVER_PORT=8080
SERVER_CONTEXT_PATH=/

# ===== DATABASE (SQL Server) =====
SPRING_DATASOURCE_URL=jdbc:sqlserver://localhost:1433;databaseName=Webcake2;encrypt=false;trustServerCertificate=true
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=your_password_here

# ===== JPA/HIBERNATE =====
JPA_DDL_AUTO=none
JPA_SHOW_SQL=false

# ===== THYMELEAF =====
THYMELEAF_CACHE=true
STATIC_CACHE_PERIOD=3600

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_LEVEL_WEB=INFO

# ===== EMAIL (Gmail App Password) =====
# Get your App Password at: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here

# ===== PROFILE =====
SPRING_PROFILES_ACTIVE=prod
